// Default openclaw.jsonc Template
//
// This template is used by default when a claw doesn't specify its own
// openclaw_json path in stack.yml.
//
// It creates main & code agents. Main runs as "non-main" inside the container.
// This template is a good starting point for most claws if you don't need specific security permissions.
// OpenClaw Control UI can be used after deployment to customize the openclaw config.
//
// To customize for a specific claw:
//   1. Copy this file to openclaw/<claw-name>/openclaw.jsonc
//   2. Set openclaw_json: openclaw/<claw-name>/openclaw.jsonc in that claw's stack.yml section
//
// Hot-reloadable (no restart needed):
//   - hooks — reloads hook handlers
//   - cron — restarts cron jobs
//   - browser — restarts browser control
//   - agents.defaults.heartbeat — restarts heartbeat
//   - Channel configs (telegram, whatsapp, etc.)
// Requires gateway restart (kind: "restart"):
//   - gateway.* settings
//   - plugins.* settings
//   - discovery.*
// Ignored (kind: "none" — detected but no action taken):
//   - agents (agent configs, sandbox settings, env vars)
//   - tools
//   - routing
//   - models
//   - logging
//   - skills
//
// ${VAR} references are resolved at startup by OpenClaw's native env var substitution.
// Docker env vars are set by docker-compose.yml (the single source of truth).
//
{
  "commands": {
    "restart": true
  },
  "gateway": {
    "bind": "lan", // Required for cloudflared (tunnel) to connect to gateway in the docker container
    "mode": "local",
    "auth": {
      "mode": "token", // OpenClaw uses OPENCLAW_GATEWAY_TOKEN env var
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000
      }
    },
    // cloudflared connects via Docker bridge gateway IP. Must be exact IPs — CIDR ranges NOT supported.
    "trustedProxies": [
      "172.30.0.1"
    ],
    "controlUi": {
      "basePath": "${OPENCLAW_DOMAIN_PATH}",
      "allowedOrigins": ["${OPENCLAW_ALLOWED_ORIGIN}"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": "${TELEGRAM_ENABLED}",
      "dmPolicy": "pairing", // Require device pairing for DMs
      "groupPolicy": "allowlist", // Only respond in explicitly allowed groups
      "streamMode": "partial" // Stream partial responses to Telegram
      // botToken read from TELEGRAM_BOT_TOKEN env var (set in docker-compose.yml)
      // WARNING: Each claw MUST use a unique bot token. Sharing tokens causes getUpdates 409 conflicts.
    },
    // Matrix channel — enabled via MATRIX_ENABLED env var (controlled by matrix.enabled in stack.yml).
    // Configure matrix: in stack.yml, set access token in .env, then run npm run pre-deploy.
    // Full config reference: https://docs.openclaw.ai/channels/matrix
    // Setup guide: docs/MATRIX.md
    "matrix": {
      "enabled": "${MATRIX_ENABLED}",
      "homeserver": "${MATRIX_HOMESERVER}",
      "accessToken": "${MATRIX_ACCESS_TOKEN}", // Access token for the Matrix bot account
      "deviceName": "OPENCLAW_GATEWAY", // Device name shown in Matrix clients' device list
      "encryption": false, // Set to true for E2EE (requires crypto module — see docs/MATRIX.md)
      "dm": { "policy": "pairing" }, // Require device pairing for DMs
      "groupPolicy": "open" // Respond in any room when @mentioned
    }
  },
  "logging": {
    "level": "info", // file log level
    "consoleLevel": "info", // console/docker log level
    "consoleStyle": "json", // Send json logs to vector -> Log Worker
    "redactSensitive": "tools" // Redact sensitive info before shipping logs
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        // Bundled with openclaw - logs sessions to agent workspace/ dir
        "session-memory": {
          "enabled": true
        },
        // Bundled with openclaw - when enabled, commands will be logged and shipped to the Log Worker via vector
        // If telemetry plugin is enabled, there's no need for the command-logger
        "command-logger": {
          "enabled": false
        }
      }
    }
  },
  "agents": {
    // Agent sandbox default settings - all agents inherit these settings & can override per agent
    "defaults": {
      // Set default models here if needed - or use openclaw cli or Control UI after deploy
      // "model": {
      //   "primary": "openai-codex/gpt-5.3-codex"
      // },
      // "models": {
      //   "openai-codex/gpt-5.3-codex": {}
      // },
      "userTimezone": "America/Los_Angeles", // Default timezone - can be updated by OpenClaw
      "sandbox": {
        // all: every agent session runs sandboxed by default.
        // Main agent overrides to "non-main" so operator DMs run on host.
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw", // Enable writes to agent sandbox - remove this here and customize per agent for tighter security controls
        "docker": {
          // "image": "openclaw-sandbox:bookworm-slim", // sandbox has the minimal base image
          "image": "openclaw-sandbox-toolkit:bookworm-slim", // sandbox-toolkit has the full toolkit bins
          "containerPrefix": "openclaw-sbx-",
          "workdir": "/workspace",
          "readOnlyRoot": true,
          // Writable scratch dirs. Per-agent tmpfs for $HOME MUST include :uid=1000,gid=1000
          // or it mounts as root-owned and the sandbox user can't write to it.
          "tmpfs": [
            "/tmp",
            "/var/tmp",
            "/run"
          ],
          "network": "bridge", // Enable network access by default; agents can selectively disable with "none"
          "user": "1000:1000", // Gets mapped to sandbox user - don't change this unless you know what you're doing
          "capDrop": [
            "ALL" // Drop all docker container privileges by default
          ],
          // Sandbox env settings
          // OpenClaw reads these when processing agent requests. e.g. Can be used to override API Keys per agent.
          // Requires a custom patch to propagate env to the sandbox containers to be used for bins.
          // See Patch #3 in build-openclaw.sh to properly set ENV vars in sandbox containers - patches missing openclaw feature.
          // Env is only propagated into the containers at container creation time.
          // Requires recreating sandboxes if you need any of these env settings in the sandbox container.
          "env": {
            "LANG": "C.UTF-8",
            // Writable HOME inside workspace — persists across sandbox restarts via
            // the workspace bind mount chain (VPS → OpenClaw Gateway .openclaw → Sandbox /workspace).
            // This is needed because readOnlyRoot is enabled - bins like codex, claude, etc. need to persist config files
            // Default HOME is /home/sandbox and is read only when readOnlyRoot is enabled
            "HOME": "/workspace/.home",
            // PATH is intentionally not set — sandbox images include the correct PATH
            // (linuxbrew, bun, system bins). Overriding it risks missing entries.
            //
            // Disable Chromium's internal sandbox in browser containers — Docker already
            // provides isolation (capDrop:ALL + no-new-privileges), and Chromium can't create
            // its own sandbox without SYS_ADMIN or user namespaces. Harmless for toolkit containers.
            "OPENCLAW_BROWSER_NO_SANDBOX": "1"
          },
          "pidsLimit": 512, // Add fork-bomb protection
          "memory": "2g", // Default agent container RAM - browser containers also inherit this setting
          "memorySwap": "4g",
          "cpus": 2 // Default agent container CPU
        },
        // Each agent has its browser container - requires the "browser" tool
        // Browsers are run in separate sandbox containers, not inside the agent sandbox
        // Move browser settings to individual agent to restrict browser use or enforce single browser container
        // Browser sessions are accessible to users via the dashboard server at OPENCLAW_DASHBOARD_DOMAIN after deploy
        // Browser containers inherit the default CPU and memory settings of their associated agent
        "browser": {
          "enabled": true,
          "image": "openclaw-sandbox-browser:bookworm-slim",
          "containerPrefix": "openclaw-sbx-browser-",
          "cdpPort": 9222,
          "vncPort": 5900,
          "noVncPort": 6080,
          "headless": false,
          "enableNoVnc": true,
          "autoStart": true,
          "autoStartTimeoutMs": 12000
        },
        // Default sandbox pruning
        // Sandbox workspace is persistent by default - pruning just helps keep resources tidy
        // Openclaw does not gracefully shutdown sandbox containers - it just kills them and re-spawns.
        // Override pruning settings per agent to prevent killing a sandbox mid task
        "prune": {
          "idleHours": 24,
          "maxAgeDays": 7
        }
      }
    },
    // List of agents
    // Agents inherit the default sandbox settings above - the configs in list are the overrides
    // Default mode:all sandboxes every session; main overrides to non-main for host access
    // All other agents should be customized as needed - the default list config is just to get you started with examples
    "list": [
      // MAIN AGENT
      {
        "id": "main",
        "default": true,
        "sandbox": {
          // Override default "all" — operator DM runs on host for full filesystem/docker access.
          // Group chats and subagent spawns still get sandboxed.
          "mode": "non-main",
          "docker": {
            // Host-status reports (health.json, maintenance.json) written by host cron scripts.
            // Bind into sandbox workspace so the read tool can access them (.host-status/health.json).
            // Needs both flags: external source (outside sandbox workspace) + reserved target (/workspace/).
            // Openclaw cron runs in an isolated session sandbox, so we need to allow external bind sources and reserved container targets.
            // cron job reads the reports and notifies user over Telegram if there are any issues.
            // The cron is redundant to the host-alert.sh cron that runs on host - it's used to allow the agent
            // to help the user debug if there are any issues. It also reports on the main Telegram channel.
            // Optionally comment this out if health_check_cron is disabled in stack.yml
            "dangerouslyAllowExternalBindSources": true,
            "dangerouslyAllowReservedContainerTargets": true,
            "binds": [
              "/home/node/.openclaw/workspace/.host-status:/workspace/.host-status:ro"
            ]
          }
        },
        "tools": {
          // No allow list needed — main runs on host and gets all tools by default.
          // gateway is available because the sandbox deny doesn't apply to host sessions.
          // Tool bins are not available on the host container, but are available via exec tool
          // since exec spawns a sandboxed container with the tool bins available.
          "deny": ["canvas", "nodes", "discord", "group:plugins"]
        },
        "subagents": {
          "allowAgents": ["code", "researcher"] // Add other agents here to allow main to spawn them; e.g. "personal", "work"
        }
      },
      // CODING AGENT
      {
        "id": "code",
        "name": "Code Agent",
        "skills": [
          "coding-agent",
          "github",
          "skill-creator",
          "gemini",
          "mcporter",
          "tmux"
        ],
        "sandbox": {
          "docker": {
            "memory": "4g", // Coding tasks need more headroom (claude code, LSPs, builds)
            "memorySwap": "8g",
            "cpus": 4
          },
          // Long prune window — don't kill a sandbox mid-way through a coding session
          "prune": {
            "idleHours": 168, // 7 days idle
            "maxAgeDays": 30
          }
        }
      },
      // RESEARCH AGENT
      // Use research agent's sandboxed browser to login to specific websites for accessing info
      {
        "id": "researcher",
        "name": "Research Agent",
        // "skills": [
        //   // List skills here to pre-enable or enable them later in Control UI
        // ],
        "tools": {
          // Agent doesn't need to spawn other agents — that's main's job
          "deny": ["sessions_spawn"]
        }
      }
    ]
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "telemetry", // Unified telemetry — replaces llm-logger plugin and debug-logger hook
      "memory-core" // File-backed memory search tools
      // @openclaw/matrix is bundled with OpenClaw — no allow entry needed; declare in entries below
    ],
    "load": {
      "paths": ["/app/openclaw-stack/plugins"] // Load directly from openclaw-stack mount — avoids copying into OpenClaw's namespace
    },
    "slots": {
      "memory": "memory-core" // Bundled memory plugin — provides memory_search and memory_get tools
    },
    "entries": {
      // Telemetry Plugin
      // Unified telemetry — captures LLM, session, tool, message, agent, and gateway events.
      // Replaces both llm-logger plugin and debug-logger hook.
      // Ships to: local JSONL file, Log Worker /openclaw/events (D1), and Log Worker /llemtry (Langfuse).
      // Requires gateway restart (plugins.* not hot-reloadable).
      "telemetry": {
        "enabled": true,
        "config": {
          "instanceId": "${OPENCLAW_INSTANCE_ID}",
          "hostname": "${VPS_HOSTNAME}",
          "logFile": "telemetry.log", // Set to empty string to disable file logging
          // Remote event shipping to Log Worker /openclaw/events → D1 database
          "events": {
            "enabled": "${ENABLE_EVENTS_LOGGING}",
            "url": "${EVENTS_URL}",
            "authToken": "${LOG_WORKER_TOKEN}",
            "batchSize": 50,
            "flushIntervalMs": 10000
          },
          // LLM telemetry → Langfuse (via /llemtry endpoint)
          "llemtry": {
            "enabled": "${ENABLE_LLEMTRY_LOGGING}",
            "url": "${LLEMTRY_URL}",
            "authToken": "${LOG_WORKER_TOKEN}"
          },
          // Per-category granularity: "full" | "summary" | "metadata" | "off"
          "categories": {
            "llm": "full",
            "session": "full",
            "tool": "summary",
            "message": "summary",
            "agent": "full",
            "gateway": "metadata"
          }
        }
      },
      // Memory Core Plugin
      // Bundled file-backed memory — provides memory_search and memory_get tools.
      // Loaded from /app/extensions/memory-core/ (ships with OpenClaw).
      "memory-core": {
        "enabled": true
      },
      // Matrix Channel Plugin
      // @openclaw/matrix is bundled with OpenClaw — no install step needed.
      // Plugin key is "matrix" (unscoped). Always loaded; channel activation
      // is controlled by channels.matrix.enabled, not this field.
      "matrix": {
        "enabled": true
      }
    }
  },
  // Model provider configuration
  // baseUrl routes requests through the AI gateway proxy (set in docker-compose.yml).
  // models: [] preserves the full built-in model catalog — no need to enumerate models.
  "models": {
    "providers": {
      "anthropic": {
        "baseUrl": "${ANTHROPIC_BASE_URL}",
        "models": []
      },
      "openai-codex": {
        "baseUrl": "${OPENAI_CODEX_BASE_URL}",
        "models": []
      },
      "openai": {
        "baseUrl": "${OPENAI_BASE_URL}",
        "models": []
      }
    }
  },
  // Default tool settings — override per-agent in agents.list
  "tools": {
    // Elevated mode — escape hatch for running exec on host from a sandboxed session
    // Gated to specific sender IDs. Use /elevated on in chat to activate, /elevated off to deactivate.
    // /elevated full skips exec approval prompts — use sparingly.
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "telegram": ["${ADMIN_TELEGRAM_ID}"]
        // Add other channels as needed:
        // "discord": ["your-discord-id"],
        // "whatsapp": ["+15555550123"]
      }
    },
    "sandbox": {
      "tools": {
        // Comment out tools if you don't need them
        // Each tool increases the size of the system prompt and increases the blast radius of prompt injections
        "allow": [
          "exec",
          "process",
          "read",
          "write",
          "edit",
          "apply_patch", // Allow LLM to apply patches to files instead of individual edits
          "browser", // Each agent can spawn a browser unless it explicitly denies in agent's tools list
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn", // Can spawn other agents
          "session_status",
          "cron", // Enable for host status monitoring — agents can schedule checks on health/maintenance data
          "memory_search", // memory-core plugin — explicit allow since group:plugins is denied
          "memory_get"
        ],
        "deny": [
          "canvas",
          "nodes",
          "discord",
          "gateway", // Prevent sandboxed agents from manipulating the gateway — main gets it via per-agent allow
          "group:plugins" // Block unknown plugin tools — explicitly allow known ones above
        ]
      }
    }
  }
}
