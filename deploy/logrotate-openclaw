# OpenClaw application log rotation (always-multi-claw layout)
# Rotates hook-generated JSONL logs and backup cron log for all claw instances.
# Docker container logs are rotated separately via json-file driver (docker-compose.override.yml).
#
# copytruncate: safe for append-only writers (fs.appendFile, >>)
#   — truncates the original file in-place after copying, so the writing
#   process never loses its file handle. Tiny window of log loss is acceptable.
# delaycompress: keeps most recent rotated file (.1) uncompressed for easy inspection.
# su: required to suppress logrotate's "insecure permissions" check — the logs/
#   directory is owned by uid 1000 (group-writable). Using root:root so logrotate
#   can traverse {{INSTALL_DIR}} (owned by openclaw user, mode 700).

{{INSTALL_DIR}}/instances/*/.openclaw/logs/backup.log
{
    su root root
    weekly
    rotate 4
    missingok
    notifempty
    copytruncate
    delaycompress
    compress
}

# Telemetry log — captures all event types (LLM, session, tool, agent, etc.).
# More aggressive rotation: daily + 50M maxsize trigger for mid-day rotation.
{{INSTALL_DIR}}/instances/*/.openclaw/logs/telemetry.log
{
    su root root
    daily
    rotate 7
    maxsize 50M
    missingok
    notifempty
    copytruncate
    delaycompress
    compress
}
