# Example claw configuration — copy this directory to create a new claw:
#   cp -r deploy/openclaws/_example deploy/openclaws/my-claw
# Overrides values from openclaw-config.env (the defaults).
# Only set values that differ from the defaults.
# The _ prefix marks this as disabled — openclaw-multi.sh skips _prefixed dirs.
#
# Config files (openclaw.json, models.json) are layered:
#   1. deploy/openclaws/_defaults/* (shared templates)
#   2. deploy/openclaws/<name>/*    (claw-specific overrides, if present)
# To customize openclaw.json for this claw, copy _defaults/openclaw.json here.

# Instance identity - used in container name (openclaw-<dirname>) and log differentiation
OPENCLAW_INSTANCE_ID=my-example-claw

# Domain — must be a 2nd-level subdomain (NOT 3rd-level like personal.openclaw.example.com)
# Cloudflare free SSL only covers *.example.com — deeper subdomains won't get auto SSL.
# Good: openclaw-personal.example.com, personalclaw.example.com
# Bad:  personal.openclaw.example.com (3rd-level, no auto SSL)
OPENCLAW_DOMAIN=example-openclaw.example.com
OPENCLAW_DASHBOARD_DOMAIN=example-openclaw.example.com
OPENCLAW_DASHBOARD_DOMAIN_PATH=/dashboard

# Cloudflare Tunnel Token - set here only when needing to use a different tunnel per claw
# Defaults to the tunnel in openclaw-config.env. Multiple claws can use the same tunnel
# but with different subdomain routes.
# CF_TUNNEL_TOKEN=

# Ports — auto-assigned if empty (base + alphabetical index)
# INSTANCE_GATEWAY_PORT=18789
# INSTANCE_DASHBOARD_PORT=6090

# Gateway auth token — auto-generated on first deploy if empty
# Commented out GATEWAY_TOKEN here if you want all your claws to use the
# same GATEWAY_TOKEN auto generated in openclaw-config.env (not recommended)
GATEWAY_TOKEN=

# Resource limits — override defaults from openclaw-config.env
# GATEWAY_CPUS=3
# GATEWAY_MEMORY=5G

# Telegram — per-instance bot (optional, leave empty to disable)
# OPENCLAW_TELEGRAM_BOT_TOKEN=

# AI Gateway — per-instance override (optional, falls back to shared)
# AI_GATEWAY_AUTH_TOKEN=
# AI_GATEWAY_WORKER_URL=
