# Main claw — the default OpenClaw instance.
# Inherits all settings from openclaw-config.env.
# Per-claw customizations (AGENTS.md, SOUL.md, openclaw.json overrides) go in this directory.

# Instance identity — used in container name (openclaw-main-claw) and log differentiation
OPENCLAW_INSTANCE_ID=main-claw

# Domain — inherits OPENCLAW_DOMAIN from openclaw-config.env by default.
# Uncomment to override:
# OPENCLAW_DOMAIN=openclaw.example.com
# OPENCLAW_DASHBOARD_DOMAIN=openclaw.example.com
# OPENCLAW_DASHBOARD_DOMAIN_PATH=/dashboard
