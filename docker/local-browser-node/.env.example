# === Cloudflare Access ===
# External gateway domain (behind CF Access)
GATEWAY_DOMAIN=openclaw.example.com

# Service token: CF Dashboard → Zero Trust → Access → Service Tokens
CF_ACCESS_CLIENT_ID=your-client-id
CF_ACCESS_CLIENT_SECRET=your-client-secret

# === OpenClaw Gateway ===
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# === Node Identity ===
NODE_DISPLAY_NAME=local-browser-node

# === Build ===
# stable = latest release tag, latest = main branch, or specific tag (e.g. v2026.2.26)
OPENCLAW_VERSION=stable

# === Advanced ===
# The cloudflared sidecar proxies through CF Access on localhost.
# Only change these if running without the sidecar (direct connection).
# GATEWAY_HOST=127.0.0.1
# GATEWAY_PORT=18789
# GATEWAY_TLS=false
