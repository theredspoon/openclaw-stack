.DS_Store
certs/
*.env
*.key

# Multi-instance configs: only track the example, ignore real instances
# Copy _example-claw/ to create your own (e.g., deploy/openclaws/personal-claw/)
deploy/openclaws/*
!deploy/openclaws/_example/
!deploy/openclaws/_example/config.env

tmp/
_bak/
source/

openclaw-config.env
node_modules/

# Worker configs contain environment-specific values (D1 database IDs, worker names).
# Use wrangler.jsonc.example as template — see playbooks/01-workers.md.
workers/*/wrangler.jsonc

# Local sync of /home/node/.openclaw/media/ via the scripts/sync-media.sh script
media/

agents/
screencasts/
.deploy-logs/
