.DS_Store
certs/
*.env
!openclaws/main-claw/config.env
!openclaws/_example/config.env
*.key

# Multi-claw configs: track _defaults/, _example/, and main-claw/; ignore user-created claws
# Copy _example/ to create your own (e.g., openclaws/my-claw/)
openclaws/*
!openclaws/_defaults/
!openclaws/_example/
!openclaws/main-claw/

# Synced from VPS via scripts/sync-configs.sh (large data, not for version control)
openclaws/*/workspace/
openclaws/*/sandboxes-home/

tmp/
_bak/
source/

.wrangler/

openclaw-config.env
node_modules/

# Worker configs contain environment-specific values (D1 database IDs, worker names).
# Use wrangler.jsonc.example as template — see playbooks/01-workers.md.
workers/*/wrangler.jsonc

# Local sync of /home/node/.openclaw/media/ via the scripts/sync-media.sh script
media/

agents/
screencasts/
.deploy-logs/

# CLI binary (built from cli/)
/claw
