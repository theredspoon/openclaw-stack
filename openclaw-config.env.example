# === REQUIRED TO START DEPLOYMENT ===
VPS1_IP=15.x.x.1
CF_TUNNEL_TOKEN=                   # Create tunnel first: see docs/CLOUDFLARE-TUNNEL.md
YOUR_TELEGRAM_ID=                  # Required — send message to @userinfobot to get your numeric user ID
OPENCLAW_TELEGRAM_BOT_TOKEN=       # Required — create via @BotFather (see docs/TELEGRAM.md). Can reuse for host alerter below.

# === SSH ===
SSH_KEY_PATH=~/.ssh/vps1_openclaw_ed25519
SSH_USER=ubuntu                    # Initial SSH user — set to match your VPS provider (ubuntu, root, debian, etc.)
SSH_PORT=22                        # Current SSH port, updated to SSH_HARDENED_PORT value after hardening
SSH_HARDENED_PORT=222              # Configurable target SSH port for hardening (removed after hardening completes)

# === DOMAIN CONFIGURATION (required — set up tunnel routes + Cloudflare Access first) ===
# Configure your Cloudflare Tunnel public hostname routes and Cloudflare Access
# application BEFORE starting deployment. See docs/CLOUDFLARE-TUNNEL.md.
OPENCLAW_DOMAIN=openclaw.<example>.com
OPENCLAW_DOMAIN_PATH=               # URL subpath for gateway UI (no trailing slash), leave blank for root
OPENCLAW_DASHBOARD_DOMAIN=openclaw.<example>.com
OPENCLAW_DASHBOARD_DOMAIN_PATH=/dashboard    # Dashboard base path (e.g., /dashboard), leave blank if using a separate subdomain
# Cloudflare Tunnel should route this to http://localhost:6090

# === CLOUDFLARE WORKERS (auto-deployed if placeholders remain) ===
# These are worker URLs and auth tokens (infrastructure). Provider API keys
# (ANTHROPIC_API_KEY, OPENAI_API_KEY) are configured post-deploy as Worker
# secrets — see docs/AI-GATEWAY-CONFIG.md.
AI_GATEWAY_WORKER_URL=https://ai-gateway-proxy.<account>.workers.dev
AI_GATEWAY_AUTH_TOKEN=<worker-auth-token>

# === LOG SHIPPING (optional — only needed if deploying Vector) ===
# Vector ships Docker container logs to the Cloudflare Log Receiver Worker.
# These values go into vector/.env on the VPS (separate from the gateway .env).
LOG_WORKER_URL=https://log-receiver.<account>.workers.dev/logs
LOG_WORKER_TOKEN=<generated-token>
ENABLE_VECTOR_LOG_SHIPPING=true    # Set to false to skip Vector startup and health checks on the VPS

# === OPTIONAL ===
VPS_HOSTNAME=                                  # Friendly hostname (e.g., "openclaw-dev"). Replaces cryptic provider hostname. Skipped if empty.
# Host alerter (disk/memory/CPU alerts via Telegram)
# Can reuse the same bot as OPENCLAW_TELEGRAM_BOT_TOKEN above.
# See docs/TELEGRAM.md for setup instructions.
HOSTALERT_TELEGRAM_BOT_TOKEN=
HOSTALERT_TELEGRAM_CHAT_ID=
# Daily health report time - sent via Telegram
HOSTALERT_DAILY_REPORT_TIME="9:30 AM PST"     # Any human-readable date in quotes, converted to cron by Claude

# ── Deployment Record (auto-generated) ───────────────────
# Written by playbooks as values are generated. Safety net
# in case the session ends before the deployment report.
# DEPLOYED: ADMINCLAW_PASSWORD=
# DEPLOYED: OPENCLAW_PASSWORD=
# DEPLOYED: GATEWAY_TOKEN=
# DEPLOYED: GATEWAY_URL=
