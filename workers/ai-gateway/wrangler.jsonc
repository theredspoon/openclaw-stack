{
  "name": "openclaw-ai-gateway-proxy",
  "main": "src/index.ts",
  "workers_dev": true,
  "preview_urls": false,

  "compatibility_date": "2026-02-06",

  // Workers Logs: enables console.log in the worker
  "observability": {
    "enabled": true
  },

  // Smart placement for reduced latency
  "placement": {
    "mode": "smart"
  },

  "vars": {
    // CF AI Gateway ID (optional). When CF_AI_GATEWAY_TOKEN, CF_AI_GATEWAY_ACCOUNT_ID,
    // and CF_AI_GATEWAY_ID are all set, the worker routes through Cloudflare AI Gateway.
    // Otherwise, it routes directly to provider APIs (Anthropic, OpenAI).
    // Auto-detected at runtime — no code changes needed to switch modes.
    "CF_AI_GATEWAY_ID": "openclaw-ai-gateway",
    "LOG_LEVEL": "debug"
    // Secrets (set via `wrangler secret put`):
    // Secrets survive `wrangler deploy` and will not be overwritten during new deploys
    //
    // Required (set during deployment):
    //   AUTH_TOKEN            — token clients use to authenticate to this worker
    //
    // Set post-deploy (see docs/AI-GATEWAY-CONFIG.md):
    //   OPENAI_API_KEY        — forwarded to OpenAI (required for OpenAI models)
    //   ANTHROPIC_API_KEY     — forwarded to Anthropic (required for Anthropic models)
    //   CLAUDE_CODE_OAUTH_TOKEN — claude code setup token
    //
    // Optional (CF AI Gateway mode only):
    //   CF_AI_GATEWAY_ACCOUNT_ID — Cloudflare account ID (`wrangler whoami` to find it)
    //   CF_AI_GATEWAY_TOKEN      — authenticates requests to Cloudflare AI Gateway
  }
}
