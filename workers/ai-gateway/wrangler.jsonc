{
  "name": "openclaw-ai-gateway-proxy",
  "main": "src/index.ts",

  "compatibility_date": "2026-02-06",

  // Workers Logs: enables console.log in the worker
  "observability": {
    "enabled": true
  },

  // Smart placement for reduced latency
  "placement": {
    "mode": "smart"
  },

  "vars": {
    // Set CF_AI_GATEWAY_ID to your upstream Cloudflare AI Gateway ID
    // This is the AI Gateway the worker is proxying, see also CF_AI_GATEWAY_TOKEN
    "CF_AI_GATEWAY_ID": "openclaw-ai-gateway",
    "LOG_LEVEL": "debug"
    // Secrets (set via `wrangler secret put`):
    // Secrets survive `wrangler deploy` and will not be overwritten during new deploys
    //   "ACCOUNT_ID": "YOUR_CLOUDFLARE_ACCOUNT_ID", - use `wrangler whoami` to get account ID
    //   AUTH_TOKEN       — token clients use to authenticate to this worker
    //   OPENAI_API_KEY   — forwarded to OpenAI via AI Gateway
    //   ANTHROPIC_API_KEY — forwarded to Anthropic via AI Gateway
    //   CLAUDE_CODE_OAUTH_TOKEN - claude code setup token
    //   CF_AI_GATEWAY_TOKEN — authenticates requests to Cloudflare AI Gateway
  }
}
